' ============================================
' 2. SEQUENCE DIAGRAM - Device Heartbeat Flow
' ============================================
@startuml SequenceDeviceHeartbeat
actor "IoT Device" as Device
participant "Device Controller" as Controller
participant "Device Model" as Model
participant "Device Health Service" as HealthService
database "MongoDB" as DB

Device -> Controller: POST /api/devices/heartbeat\n{serialNumber, batteryLevel, signalStrength}
activate Controller

Controller -> Model: findOne({serialNumber})
activate Model
Model -> DB: Query Device
DB --> Model: Device Data
Model --> Controller: Device Object
deactivate Model

Controller -> Model: Update device status
activate Model
Model -> DB: Update lastPing, status, batteryLevel, signalStrength
DB --> Model: Updated Device
Model --> Controller: Success
deactivate Model

Controller -> HealthService: Calculate Health Score
activate HealthService
HealthService -> HealthService: Calculate: (battery*0.3 + signal*0.3 + uptime*0.4)
HealthService -> DB: Save Health Record
DB --> HealthService: Saved
HealthService --> Controller: Health Score
deactivate HealthService

Controller --> Device: {message: "Heartbeat received", config}
deactivate Controller

@enduml

' ============================================
' 3. SEQUENCE DIAGRAM - Manager Profile View
' ============================================
@startuml SequenceManagerProfile
actor Manager
participant "Frontend" as Frontend
participant "Profile Controller" as Controller
participant "Manager Profile Model" as ProfileModel
participant "Stats Service" as StatsService
participant "Detection Model" as DetectionModel
database "MongoDB" as DB

Manager -> Frontend: Navigate to Profile Page
Frontend -> Controller: GET /api/profile/:managerId
activate Controller

Controller -> ProfileModel: findOne({Manager_Id})
activate ProfileModel
ProfileModel -> DB: Query Manager Profile
DB --> ProfileModel: Profile Data
ProfileModel --> Controller: Profile Object
deactivate ProfileModel

Controller -> StatsService: Get Performance Stats
activate StatsService
StatsService -> DetectionModel: countDocuments({userId})
StatsService -> DetectionModel: aggregate(detections by type)
StatsService -> DB: Query Detections
DB --> StatsService: Detection Stats
StatsService --> Controller: Performance Metrics
deactivate StatsService

Controller -> ProfileModel: Calculate Performance Score
activate ProfileModel
ProfileModel --> Controller: Updated Score
deactivate ProfileModel

Controller --> Frontend: {profile, stats, achievements}
Frontend --> Manager: Display Profile Page
deactivate Controller

@enduml

' ============================================
' 4. STATE CHART DIAGRAM - Device Status
' ============================================
@startuml StateDeviceStatus
[*] --> Offline: Device Registered

Offline --> Online: Heartbeat Received
Online --> Offline: No Heartbeat (Timeout)
Online --> Maintenance: Admin Sets Maintenance
Maintenance --> Online: Maintenance Complete
Maintenance --> Offline: Device Disabled

state Online {
  [*] --> Normal
  Normal --> LowBattery: Battery < 20%
  Normal --> LowSignal: Signal < 30%
  LowBattery --> Normal: Battery Charged
  LowSignal --> Normal: Signal Restored
  LowBattery --> Critical: Battery < 10%
  LowSignal --> Critical: Signal < 10%
  Critical --> Maintenance: Requires Attention
}

Offline --> [*]: Device Deleted

@enduml

' ============================================
' 5. STATE CHART DIAGRAM - Field Status
' ============================================
@startuml StateFieldStatus
[*] --> Unassigned: Field Created

Unassigned --> Active: Manager Assigned
Active --> Inactive: Admin Deactivates
Active --> Maintenance: Maintenance Required
Inactive --> Active: Reactivated
Maintenance --> Active: Maintenance Complete
Maintenance --> Inactive: Permanently Disabled

state Active {
  [*] --> Monitoring
  Monitoring --> Alert: Detection Triggered
  Alert --> Monitoring: Alert Handled
  Monitoring --> Maintenance: Issue Detected
}

Inactive --> [*]: Field Deleted
Maintenance --> [*]: Field Deleted

@enduml

' ============================================
' 6. ACTIVITY DIAGRAM - Field Assignment Process
' ============================================
@startuml ActivityFieldAssignment
start
:Admin selects Property;
:Admin clicks "Assign Manager";
:System displays unassigned managers;
:Admin selects Manager;
:Admin enters Plantation Info;
:Admin adds Fields;
repeat
  :Enter Field Name;
  :Add Field to List;
repeat while (More Fields?) is (yes)
->no;
:Admin submits form;
:Validate Manager exists;
:Validate Manager is active;
:Validate Property exists;
if (Validation successful?) then (yes)
  :Update Property with Manager;
  :Update Manager with Plantation Info;
  :Save Fields to Database;
  :Send Notification Email to Manager;
  :Display Success Message;
else (no)
  :Display Error Message;
  stop
endif
stop

@enduml

' ============================================
' 7. ACTIVITY DIAGRAM - Animal Detection Flow
' ============================================
@startuml ActivityDetectionFlow
start
:Camera captures image/video;
:Send to ML Service (YOLO);
:ML Service processes image;
:Animal detected?;
if (Detection?) then (yes)
  :Calculate confidence score;
  :Save detection to database;
  :Check if target animal;
  if (Target animal?) then (yes)
    :Check confidence >= threshold;
    if (High confidence?) then (yes)
      :Activate deterrent system;
      :Send critical alert (SMS + WhatsApp + Call);
    else (no)
      :Send warning alert (SMS + WhatsApp);
    endif
  else (no)
    :Log detection only;
    :Send info alert (SMS);
  endif
  :Update manager profile stats;
  :Update field statistics;
  :Update device health metrics;
else (no)
  :Continue monitoring;
endif
stop

@enduml

' ============================================
' 8. CLASS DIAGRAM - Core Models
' ============================================
@startuml ClassDiagram
package "User Management" {
  class User {
    -ObjectId _id
    -String userId
    -String name
    -String email
    -String phone
    -String role
    -Plantation plantation
    -Permissions permissions
    -Boolean isActive
    -Date lastLogin
    +login()
    +logout()
    +updateProfile()
  }
  
  class ManagerProfile {
    -ObjectId _id
    -ObjectId Manager_Id
    -Number totalDetections
    -Number totalProperties
    -Number totalCameras
    -Number performanceScore
    -Array achievements
    -Date lastActiveDate
    +calculatePerformanceScore()
    +updateStats()
    +addAchievement()
  }
}

package "Device Management" {
  class Device {
    -ObjectId _id
    -String serialNumber
    -String type
    -String status
    -Number batteryLevel
    -Number signalStrength
    -Date lastPing
    -ObjectId assignedProperty
    +sendHeartbeat()
    +updateStatus()
  }
  
  class DeviceHealth {
    -ObjectId _id
    -ObjectId Device_Id
    -String status
    -Number batteryLevel
    -Number signalStrength
    -Number healthScore
    -Number uptime
    -Date lastPing
    +calculateHealthScore()
    +updateHealthMetrics()
  }
}

package "Field Management" {
  class Field {
    -ObjectId _id
    -String FieldName
    -ObjectId Plantation_Id
    -ObjectId Manager_Id
    -String location
    -Object coordinates
    -String status
    -Number cameraCount
    -Number totalDetections
    +assignToManager()
    +updateStatus()
    +getStatistics()
  }
  
  class Property {
    -ObjectId _id
    -String name
    -String address
    -ObjectId managerId
    -Plantation plantation
    -Number cameraCount
    -String status
    +assignManager()
    +updateProperty()
  }
}

package "Detection System" {
  class Detection {
    -ObjectId _id
    -ObjectId userId
    -ObjectId propertyId
    -String label
    -Number probability
    -Date detectedAt
    -String source
    +createDetection()
    +getDetections()
  }
  
  class Notification {
    -ObjectId _id
    -ObjectId Detection_Id
    -ObjectId Manager_Id
    -String channel
    -String status
    -Date sentAt
    -Number retries
    +sendNotification()
    +updateStatus()
  }
}

' Relationships
User "1" --> "1" ManagerProfile : has
User "1" --> "*" Property : manages
Property "1" --> "*" Field : contains
Device "1" --> "1" DeviceHealth : has
Device "*" --> "1" Property : assigned to
Detection "*" --> "1" User : detected by
Detection "*" --> "1" Property : detected at
Notification "*" --> "1" Detection : references
Notification "*" --> "1" User : sent to
Field "*" --> "1" User : assigned to

@enduml

