## Backend environment variables
NODE_ENV=production
PORT=5000

# Comma-separated list of allowed frontend origins for CORS
# Example (local + prod):
# CORS_ORIGIN=http://localhost:5173,https://sadsweb.xyz
CORS_ORIGIN=http://localhost:5173

# Used in password reset links
FRONTEND_URL=http://localhost:5173

# SECURITY: Set strong secrets in production
JWT_SECRET=change-me

# Database
MONGODB_URI=

# Optional: Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: SMTP (email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=SADS System <no-reply@sads.local>

# Optional: Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=+14155238886

