{
  "name": "sads",
  "version": "1.0.0",
  "description": "Smart Animal Deterrent System",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "selenium-tests"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "build": "npm run build --workspace=frontend",
    "start": "npm run start --workspace=backend",
    "test": "npm run test --workspace=backend && npm run test --workspace=selenium-tests"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
